# freemac direct public IPv6 + high-port runtime environment
# Use a high port to avoid 80/443 conflicts and reduce firewall friction.
FREEMAC_HOST=::
FREEMAC_WEB_DIST=__FREEMAC_ROOT__/apps/web/dist
FREEMAC_DATA_DIR=__FREEMAC_ROOT__/.data/direct-ipv6
FREEMAC_DDNS_INTERVAL_MS=300000
FREEMAC_TELEMETRY_INTERVAL_MS=5000
FREEMAC_DDNS_OBSERVATION_URLS=https://api64.ipify.org,https://ipv6.icanhazip.com
FREEMAC_RELAY_ORIGIN=
FREEMAC_RELAY_REPORT_INTERVAL_MS=60000
